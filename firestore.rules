rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.superAdmin == true;
    }

    // Caller belongs to this society (active claim matches path segment)
    function isMember(societyId) {
      return isSignedIn() && request.auth.token.societyId == societyId;
    }

    // Caller has a specific role in this society
    function hasRole(societyId, role) {
      return isMember(societyId) && request.auth.token.role == role;
    }

    // Caller is admin or FM in this society
    function isAdminOrFM(societyId) {
      return isMember(societyId) &&
        (request.auth.token.role == 'admin' || request.auth.token.role == 'fm');
    }

    // ── Top-level: Memberships ────────────────────────────────────────────────
    // id = uid_societyId; written by Functions only (inviteUser, refreshClaims)
    match /memberships/{membershipId} {
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        isSuperAdmin() ||
        (request.auth.token.societyId == resource.data.societyId
         && request.auth.token.role == 'admin')
      );
      // Writes are Functions-only (inviteUser, refreshClaims, updateMembership callables)
      allow write: if false;
    }

    // ── Top-level: Users (global profile) ────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read: if isSuperAdmin();
    }

    // ── Top-level: Societies ──────────────────────────────────────────────────
    // Super admin creates; members read their own society
    match /societies/{societyId} {
      allow read:   if isSuperAdmin() || isMember(societyId);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || hasRole(societyId, 'admin');
      allow delete: if isSuperAdmin();

      // ── Society sub-collections ─────────────────────────────────────────────

      // Accounts — admin manages; FM reads
      match /accounts/{accountId} {
        allow read:   if isAdminOrFM(societyId);
        allow write:  if hasRole(societyId, 'admin');
      }

      // Fund heads — admin manages; FM reads
      match /fundHeads/{fundHeadId} {
        allow read:   if isAdminOrFM(societyId);
        allow write:  if hasRole(societyId, 'admin');
      }

      // Vendors — admin + FM manage; all members read
      match /vendors/{vendorId} {
        allow read:   if isMember(societyId);
        allow write:  if isAdminOrFM(societyId);
      }

      // Vendor relations — income/expense edge on a vendor
      match /vendorRelations/{relId} {
        allow read:   if isMember(societyId);
        allow write:  if isAdminOrFM(societyId);
      }

      // Recurring payment templates — admin manages; all members read
      match /recurringPayments/{rpId} {
        allow read:  if isMember(societyId);
        allow write: if hasRole(societyId, 'admin');
      }

      // Recurring instances — Functions-only writes; members read
      match /recurringInstances/{instanceId} {
        allow read:  if isMember(societyId);
        allow write: if false;
      }

      // Expense requests — all writes via Functions (callables); members read
      match /expenseRequests/{requestId} {
        allow read:   if isMember(societyId);
        allow write:  if false;  // createMaintenanceRequest / scheduleSnag / submitExpenseRequest / etc.

        // Quotations — FM/Admin upload metadata; all members read
        match /quotations/{quoteId} {
          allow read:             if isMember(societyId);
          allow create:           if isAdminOrFM(societyId);
          allow update, delete:   if false;
        }

        // Approvals — recordApproval callable only
        match /approvals/{approvalId} {
          allow read:  if isMember(societyId);
          allow write: if false;
        }

        // Notes — any member can add (UI restricts to MC); immutable once written
        match /notes/{noteId} {
          allow read:           if isMember(societyId);
          allow create:         if isMember(societyId);
          allow update, delete: if false;
        }

        // Disbursements — recordDisbursement callable only
        match /disbursements/{disbId} {
          allow read:  if isMember(societyId);
          allow write: if false;
        }
      }

      // Transactions — Functions-only writes; members read
      match /transactions/{txId} {
        allow read:  if isMember(societyId);
        allow write: if false;
      }

      // Balances — Functions-only
      match /balances/{balanceId} {
        allow read:  if isAdminOrFM(societyId);
        allow write: if false;
      }

      // Audit logs — Functions-only; admin reads
      match /auditLogs/{logId} {
        allow read:  if hasRole(societyId, 'admin') || isSuperAdmin();
        allow write: if false;
      }

      // Society config (tier settings, etc.) — admin manages
      match /config/{configId} {
        allow read:  if isMember(societyId);
        allow write: if hasRole(societyId, 'admin');
      }

      // Units registry — Admin manages; all members read
      match /units/{unitId} {
        allow read:  if isMember(societyId);
        allow write: if hasRole(societyId, 'admin');
      }

      // Collection periods (summary docs) — importCollections callable writes; Admin/FM read
      match /collections/{period} {
        allow read:  if isAdminOrFM(societyId);
        allow write: if false;  // importCollections callable only

        // Collection entries — Admin/FM can mark paid/pending; importCollections callable writes
        match /entries/{entryId} {
          allow read:   if isAdminOrFM(societyId);
          allow update: if isAdminOrFM(societyId);
          allow create, delete: if false;  // importCollections callable only
        }
      }

      // Vendor income — Admin/FM create + update; Admin/FM read
      match /vendorIncome/{incomeId} {
        allow read:   if isAdminOrFM(societyId);
        allow create: if isAdminOrFM(societyId);
        allow update: if isAdminOrFM(societyId);
        allow delete: if false;
      }

      // Notifications — Functions-only writes; each user reads and marks their own
      match /notifications/{notificationId} {
        allow read:   if isMember(societyId) && request.auth.uid == resource.data.toUid;
        allow update: if isMember(societyId) && request.auth.uid == resource.data.toUid
                         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
        allow create, delete: if false;
      }
    }

    // Default deny — everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
