rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.superAdmin == true;
    }

    // Caller belongs to this society (claim matches path segment)
    function isMember(societyId) {
      return isSignedIn() && request.auth.token.societyId == societyId;
    }

    // Caller has a specific role in this society
    function hasRole(societyId, role) {
      return isMember(societyId) && request.auth.token.role == role;
    }

    // Caller is admin or MC in this society
    function isAdminOrMC(societyId) {
      return isMember(societyId) &&
        (request.auth.token.role == 'admin' || request.auth.token.role == 'mc');
    }

    // Caller is admin or FM in this society
    function isAdminOrFM(societyId) {
      return isMember(societyId) &&
        (request.auth.token.role == 'admin' || request.auth.token.role == 'fm');
    }

    // ── Forbidden client writes (Functions-only collections) ──────────────────
    // transactions, balances, auditLogs are written exclusively by Cloud Functions.

    // ── Top-level collections ─────────────────────────────────────────────────

    // Societies — super admin can create; members can read their own
    match /societies/{societyId} {
      allow read:   if isSuperAdmin() || isMember(societyId);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || hasRole(societyId, 'admin');
      allow delete: if isSuperAdmin();

      // ── Society sub-collections ─────────────────────────────────────────────

      // Memberships — admin manages; members read own
      match /memberships/{memberId} {
        allow read:   if isMember(societyId);
        allow write:  if isSuperAdmin() || hasRole(societyId, 'admin');
      }

      // Accounts — admin manages; FM reads
      match /accounts/{accountId} {
        allow read:   if isAdminOrFM(societyId);
        allow write:  if hasRole(societyId, 'admin');
      }

      // Fund heads — admin manages; FM reads
      match /fundHeads/{fundHeadId} {
        allow read:   if isAdminOrFM(societyId);
        allow write:  if hasRole(societyId, 'admin');
      }

      // Vendors — admin + FM manage; MC reads
      match /vendors/{vendorId} {
        allow read:   if isMember(societyId);
        allow write:  if isAdminOrFM(societyId);
      }

      // Expense requests — FM creates/withdraws; MC + Admin reads/approves
      match /requests/{requestId} {
        allow read:   if isMember(societyId);
        allow create: if isAdminOrFM(societyId);
        // Updates (approve, withdraw) handled by Functions; direct writes blocked except status-safe fields
        allow update: if isAdminOrFM(societyId);
        allow delete: if false;
      }

      // Transactions — Functions-only writes; members read
      match /transactions/{txId} {
        allow read:  if isMember(societyId);
        allow write: if false;
      }

      // Balances — Functions-only
      match /balances/{balanceId} {
        allow read:  if isAdminOrFM(societyId);
        allow write: if false;
      }

      // Audit logs — Functions-only; admin reads
      match /auditLogs/{logId} {
        allow read:  if hasRole(societyId, 'admin') || isSuperAdmin();
        allow write: if false;
      }

      // Society config (tier settings, etc.) — admin manages
      match /config/{configId} {
        allow read:  if isMember(societyId);
        allow write: if hasRole(societyId, 'admin');
      }
    }

    // Users — own profile only
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read: if isSuperAdmin();
    }

    // Default deny — everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
