# Firebase Web SDK config (client-side; not secret). Copy to .env.local and fill.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Connect the app to the local Emulator Suite in dev.
VITE_USE_EMULATORS=true

# App Check (Firebase security layer — prevents abuse of Firestore/Functions/Storage).
# For LOCAL DEV: get a debug token from the Firebase console → App Check → Apps → overflow menu.
# Set ONLY one of these per environment.
VITE_APPCHECK_DEBUG_TOKEN=   # local dev only; never commit a real value
VITE_APPCHECK_SITE_KEY=      # reCAPTCHA v3 site key; set in staging/prod .env.local
# After setting VITE_APPCHECK_SITE_KEY: enable enforcement in Firebase console for
# Firestore, Cloud Functions (asia-south1), and Storage.
